{
  "name": "clifer",
  "version": "1.11.0",
  "description": "A lightweight, type-safe TypeScript library for building beautiful command-line interfaces with zero dependencies",
  "keywords": [
    "cli",
    "command-line",
    "terminal",
    "console",
    "typescript",
    "interactive",
    "prompt",
    "commander",
    "yargs",
    "argv"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "repository": "https://github.com/rintoj/clifer.git",
  "homepage": "https://github.com/rintoj/clifer#readme",
  "bugs": {
    "url": "https://github.com/rintoj/clifer/issues"
  },
  "author": "Rinto Jose <rintoj@gmail.com>",
  "license": "MIT",
  "bin": {
    "clifer": "bin/cli"
  },
  "files": [
    "lib",
    "bin",
    "README.md",
    "API.md",
    "USAGE.md",
    "LICENSE"
  ],
  "scripts": {
    "build:cli": "rimraf dist; bun build src/cli.ts --target=bun --outdir=dist --external react-devtools-core",
    "build:lib": "rimraf lib && tsc",
    "build": "rimraf dist lib && tsc && bun build src/cli.ts --target=bun --outdir=dist --external react-devtools-core",
    "test": "bun test",
    "lint": "biome check --fix && tsc -p . --noEmit",
    "format": "biome format --write .",
    "check": "biome check .",
    "prepublish": "bun run build",
    "semantic-release": "semantic-release"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^18.7.16",
    "@types/react": "^19.0.0",
    "semantic-release": "^19.0.5",
    "typescript": "~5.4"
  },
  "dependencies": {
    "@types/fs-extra": "^11.0.4",
    "cardinal": "^2.1.1",
    "enquirer": "^2.3.6",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "ink": "^6.0.0",

    "markdown-it": "^14.1.0",
    "markdown-it-terminal": "^0.4.0",
    "name-util": "^1.3.0",
    "react": "^19.0.0",
    "strip-ansi": "6"
  }
}
